# ORE AI-RAG Pipeline - environment template.
# Copy to `.env` and edit as needed. None of these are required to run.

# Where ChromaDB stores its persistent files.
ORE_CHROMA_PATH=./chroma_db

# ChromaDB collection name.
ORE_CHROMA_COLLECTION=documents

# Folder watched by the FastAPI /upload endpoint.
ORE_DOCUMENTS_DIR=./documents
