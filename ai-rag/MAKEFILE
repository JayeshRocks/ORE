# ORE AI-RAG Pipeline - convenience commands (rag_playground/MAKEFILE port).
#
# Targets mirror the playground so muscle memory carries over.

.venv:
	python3 -m venv .venv

install:
	.venv/bin/pip install --upgrade pip
	.venv/bin/pip install -r requirements.txt

ingest:
	.venv/bin/python ingest.py

chat:
	.venv/bin/python rag_chat.py

serve:
	.venv/bin/uvicorn app:app --reload --host 0.0.0.0 --port 8000

test-chunks:
	.venv/bin/python test_chunks.py

test-embeddings:
	.venv/bin/python test_embeddings.py

test-search:
	.venv/bin/python test_search.py

clean-db:
	rm -rf chroma_db

clean: clean-db
	find . -type d -name "__pycache__" -exec rm -rf {} +
