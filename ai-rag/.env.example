# ORE AI-RAG Pipeline - environment template.
# Copy to `.env` (gitignored) and edit as needed. None are required.

# Storage
ORERAG_CHROMA_PATH=./chroma_db
ORERAG_CHROMA_COLLECTION=documents

# Documents folder
ORERAG_DOCUMENTS_DIR=./documents

# Models (Ollama)
ORERAG_EMBED_MODEL=nomic-embed-text
ORERAG_LLM_MODEL=gemma4:31b-cloud

# Chunking
ORERAG_CHUNK_SIZE=1000
ORERAG_CHUNK_OVERLAP=200

# Retrieval
ORERAG_N_RESULTS=4

# HTTP API
ORERAG_API_HOST=0.0.0.0
ORERAG_API_PORT=8000
